# ZT-ATE Frontend Environment Configuration
# Copy to .env.local and modify as needed.
# All NEXT_PUBLIC_ variables are embedded at build time.

# Backend API base URL.
# - Sentinel Node (Tauri): leave unset to default to http://127.0.0.1:8000.
# - Nexus Cloud (browser): set to your cloud API URL, for example:
#   https://api.zt-ate.example.com
# - Same-origin proxy: leave unset to use relative /api/* paths.
# NEXT_PUBLIC_API_BASE_URL=

# Deployment mode identifier for analytics/logging.
# NEXT_PUBLIC_DEPLOYMENT_MODE=SENTINEL_NODE
